# O2C Agent v2.0 — Environment Variables Template
# Copy this file to `.env` and replace placeholder values with real secrets.
# DO NOT commit `.env` or any OAuth credential files.

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# Redis — only used by Celery (currently unused; all agents/schedulers run in-process)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ChromaDB (PersistentClient — only PERSIST_PATH is read by chromadb_client.py; HOST/PORT unused)
CHROMADB_PERSIST_PATH=./chroma_data
# CHROMADB_HOST=localhost
# CHROMADB_PORT=8001

# LLM Provider — only ollama_cloud is supported
LLM_PROVIDER=ollama_cloud

# Ollama Cloud (remote GPU models, OpenAI-compatible — active provider)
OLLAMA_CLOUD_API_KEY=your_ollama_cloud_key_here
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1
OLLAMA_CLOUD_MODEL_PRIMARY=gpt-oss:120b
OLLAMA_CLOUD_MODEL_FALLBACK=gpt-oss:20b

LLM_CONFIDENCE_THRESHOLD=0.6

# JWT
JWT_SECRET_KEY=your_jwt_secret_key_here_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Email (Gmail SMTP / SMTP relay)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# ML
ML_MODELS_PATH=./ml/models
GLINER_MODEL=urchade/gliner_medium-v2.1
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Business Rules
FRAUD_BLOCK_THRESHOLD=0.70
CASH_APP_AUTO_MATCH_THRESHOLD=0.90
CREDIT_LIMIT_HITL_THRESHOLD=0.90
HITL_GATE_SOX_AMOUNT_INR=50000.0
DUNNING_MAX_CONTACTS_PER_WEEK=2

# Inventory
BACKORDER_STALE_DAYS=30
DEFAULT_SAFETY_STOCK_BUFFER_PCT=0.20

# Email Intake (Gmail OAuth poller)
POLL_INTERVAL_MINUTES=15
MAX_EMAILS_PER_CYCLE=25
PROCESSED_LABEL=o2c/processed
GMAIL_CREDENTIALS_FILE=backend/email_intake/credentials.json
GMAIL_TOKEN_FILE=backend/email_intake/token.json
LLM_CONFIDENCE_THRESHOLD=0.6
O2C_API_BASE_URL=http://localhost:8000
O2C_API_TIMEOUT=90.0
FRIEND_AGENT_URL=
FRIEND_AGENT_TIMEOUT=30.0
DB_PATH=intake_state.db
